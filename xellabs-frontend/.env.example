# Copy this file to .env.local for local development outside Docker.
# When running inside Docker these are set in docker-compose.yml — no .env needed.

# Django API — use Docker service name inside Docker, localhost outside
DJANGO_API_URL=http://django:8001

# SENAITE — use Docker service name inside Docker, localhost outside
SENAITE_URL=http://senaite:8080/senaite

# JWT session secret — must be at least 32 characters, keep secret
SESSION_SECRET=xellabs-lims-hipaa-jwt-secret-change-in-production-min32chars
