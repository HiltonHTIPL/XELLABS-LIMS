<div class="sample-labels"
     i18n:domain="senaite.core"
     tal:define="labels options/labels;
                 colors options/colors;
                 chip_style nocall:options/chip_style;">
  <tal:chip repeat="label labels">
    <span class="sample-label"
          tal:define="style python:chip_style(colors.get(label))"
          tal:attributes="data-label python:label;
                          style python:style or None">
      <span class="sample-label-text"
            tal:content="python:label" />
    </span>
  </tal:chip>
</div>
