<?xml version="1.0" encoding="UTF-8"?>
<object name="Worksheet" meta_type="Dexterity FTI"
        i18n:domain="senaite.core"
        xmlns:i18n="http://xml.zope.org/namespaces/i18n">

    <!-- Title and Description -->
    <property name="title" i18n:translate="">Worksheet</property>
    <property name="description" i18n:translate=""/>

    <!-- content-type icon -->
    <property name="icon_expr">senaite_theme/icon/worksheet</property>

    <!-- factory name; usually the same as type name -->
    <property name="factory">Worksheet</property>

    <!-- URL TALES expression to add an item TTW -->
    <property name="add_view_expr">string:${folder_url}/++add++Worksheet</property>

    <property name="link_target"/>
    <property name="immediate_view">view</property>

    <!-- Is this item addable globally, or is it restricted? -->
    <property name="global_allow">False</property>

    <!-- If we're a container, should we filter addable content types? -->
    <property name="filter_content_types">True</property>
    <!-- If filtering, what's allowed -->
    <property name="allowed_content_types">
        <element value="DuplicateAnalysis"/>
        <element value="Attachment"/>
    </property>

    <property name="allow_discussion">False</property>

    <!-- what are our available view methods, and what's the default? -->
    <property name="default_view">view</property>
    <!-- the view methods below will be selectable via the display tab -->
    <property name="view_methods">
        <element value="view"/>
    </property>
    <property name="default_view_fallback">False</property>

    <!-- permission required to add an item of this type -->
    <property name="add_permission">cmf.AddPortalContent</property>

    <!-- Python class for content items of this sort -->
    <property name="schema">senaite.core.content.worksheet.IWorksheetSchema</property>
    <property name="klass">senaite.core.content.worksheet.Worksheet</property>

    <!-- Dexterity behaviours for this type -->
    <property name="behaviors">
    <element value="bika.lims.interfaces.IAutoGenerateID"/>
    <element value="bika.lims.interfaces.IMultiCatalogBehavior"/>
    <element value="plone.app.referenceablebehavior.referenceable.IReferenceable" />
    </property>

    <!-- Action aliases -->
    <alias from="(Default)" to="(dynamic view)"/>
    <alias from="sharing" to="@@sharing"/>
    <alias from="view" to="(selected layout)"/>

    <!-- View -->
    <action title="View"
            action_id="view"
            category="object"
            condition_expr=""
            description=""
            icon_expr=""
            link_target=""
            url_expr="string:${object_url}"
            visible="False">
        <permission value="senaite.core: View Results"/>
    </action>

    <!-- Edit -->
    <action title="Edit"
            action_id="edit"
            category="object"
            condition_expr=""
            description=""
            icon_expr=""
            link_target=""
            url_expr="string:${object_url}/edit"
            visible="False">
        <permission value="Modify portal content"/>
    </action>

    <!-- Manage results -->
    <action title="Manage Results"
            action_id="manage_results"
            category="object"
            condition_expr=""
            icon_expr=""
            link_target=""
            url_expr="string:${object_url}/manage_results"
            i18n:attributes="title"
            visible="True">
        <permission value="senaite.core: View Results"/>
    </action>

    <action title="Add Analyses"
            action_id="add_analyses"
            category="object"
            condition_expr="python:context.portal_workflow.getInfoFor(context, 'review_state') not in ['verified', 'published']"
            icon_expr=""
            link_target=""
            url_expr="string:${object_url}/add_analyses"
            i18n:attributes="title"
            visible="True">
        <permission value="senaite.core: Manage Worksheets"/>
    </action>

    <action title="Add Blank Reference"
            action_id="add_blank"
            category="object"
            condition_expr="python:context.portal_workflow.getInfoFor(context, 'review_state') not in ['verified', 'published']"
            icon_expr=""
            link_target=""
            url_expr="string:${object_url}/add_blank"
            i18n:attributes="title"
            visible="True">
        <permission value="senaite.core: Manage Worksheets"/>
    </action>

    <action title="Add Control Reference"
            action_id="add_control"
            category="object"
            condition_expr="python:context.portal_workflow.getInfoFor(context, 'review_state') not in ['verified', 'published']"
            icon_expr=""
            link_target=""
            url_expr="string:${object_url}/add_control"
            i18n:attributes="title"
            visible="True">
        <permission value="senaite.core: Manage Worksheets"/>
    </action>

    <action title="Add Duplicate"
            action_id="add_duplicate"
            category="object"
            condition_expr="python:context.portal_workflow.getInfoFor(context, 'review_state') not in ['verified', 'published']"
            icon_expr=""
            link_target=""
            url_expr="string:${object_url}/add_duplicate"
            i18n:attributes="title"
            visible="True">
        <permission value="senaite.core: Manage Worksheets"/>
    </action>

    <action title="Export"
            action_id="export"
            category="object"
            condition_expr="python:context.portal_workflow.getInfoFor(context, 'review_state') not in ['verified', 'published']"
            icon_expr=""
            link_target=""
            url_expr="string:${object_url}/export"
            i18n:attributes="title"
            visible="True">
        <permission value="senaite.core: Edit Worksheet"/>
    </action>

    <action title="Sticker"
            action_id="sticker"
            category="document_actions"
            condition_expr=""
            icon_expr="string:${portal_url}/senaite_theme/icon/sticker_large"
            link_target=""
            url_expr="string:${object_url}/sticker?autoprint=1&amp;filter_by_type=worksheet"
            i18n:attributes="title"
            visible="True">
        <permission value="View"/>
    </action>

    <action title="Stickers preview"
            action_id="sticker_preview"
            category="document_actions"
            condition_expr=""
            icon_expr="string:${portal_url}/senaite_theme/icon/sticker_preview"
            link_target="Stickers preview"
            url_expr="string:${object_url}/sticker?filter_by_type=worksheet"
            i18n:attributes="title"
            visible="True">
        <permission value="View"/>
    </action>

</object>
