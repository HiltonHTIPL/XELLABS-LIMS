<html xmlns="http://www.w3.org/1999/xhtml"
      xmlns:tal="http://xml.zope.org/namespaces/tal"
      tal:omit-tag="">

  <span class="senaite-color-widget-display d-inline-flex align-items-center"
        style="gap: .35rem;">
    <span class="senaite-color-widget-swatch"
          tal:condition="view/value"
          tal:attributes="
            style string:display:inline-block;width:1rem;height:1rem;
                         border-radius:3px;border:1px solid rgba(0,0,0,.15);
                         background-color:${view/value};" />
    <code tal:condition="view/value"
          style="font-size: .75rem;"
          tal:content="view/value" />
    <span tal:condition="not:view/value"
          class="text-muted"
          i18n:translate="">(no color)</span>
  </span>
</html>
