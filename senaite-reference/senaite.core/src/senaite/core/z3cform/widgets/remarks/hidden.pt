<div xmlns="http://www.w3.org/1999/xhtml"
     xmlns:tal="http://xml.zope.org/namespaces/tal"
     tal:omit-tag=""
     tal:define="
         field_id python:view.id;
         field_name python:view.name;">

    <tal:remark repeat="remark python:view.value;">

        <input type="hidden"
               tal:repeat="key python:remark.keys()"
               tal:attributes="
                   id    string:${field_id}_${key}:records:ignore_empty;
                   name  string:${field_name}_${key}:records:ignore_empty;
                   value python:remark.get(key, '')"/>

    </tal:remark>

</div>
