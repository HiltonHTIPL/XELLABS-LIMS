# Production environment template — copy to xellabs-backend/.env and fill in real values
# NEVER commit the real .env file

DEBUG=False
SECRET_KEY=<generate-with: python -c "import secrets; print(secrets.token_urlsafe(50))">

# Domain
DOMAIN=lims.yourdomain.com
ALLOWED_HOSTS=lims.yourdomain.com

# Database
DB_NAME=xellabs_lims
DB_USER=xellabs_user
DB_PASSWORD=<strong-random-password>
DB_HOST=postgres
DB_PORT=5432

# Redis / Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Email (for alerts, hypercare notifications)
EMAIL_HOST=smtp.yourdomain.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@yourdomain.com
EMAIL_HOST_PASSWORD=<email-password>
DEFAULT_FROM_EMAIL=XelLabs LIMS <noreply@yourdomain.com>

# SENAITE admin
SENAITE_ADMIN_USER=admin
SENAITE_ADMIN_PASSWORD=<strong-random-password>

# Security
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
