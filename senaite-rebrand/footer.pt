<footer i18n:domain="senaite.core"
        id="senaite-footer">

  <div class="row">
    <div class="col-md-12">
      <hr/>
      <!-- footer portlets -->
      <div tal:on-error="nothing" tal:replace="structure view/render_footer_portlets" />
      <div class="float-left">
        <span i18n:translate="description_copyright" tal:omit-tag="">
          <abbr title="Copyright" i18n:name="copyright" i18n:attributes="title title_copyright;">&copy;</abbr>
          2017-<tal:year i18n:name="current_year" tal:content="view/year" />
          <span i18n:name="senaitelims" tal:omit-tag="">
            XelLabs LIMS
          </span>
        </span>
      </div>
      <div class="float-right">
        <ul class="nav nav-pills">
          <li><a class="nav-link" href="#" title="XelLabs"><i class="fas fa-flask"></i></a></li>
        </ul>
      </div>
    </div>
  </div>
</footer>
